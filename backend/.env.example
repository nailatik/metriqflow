# ─── Runtime ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=8000

# ─── Logging ───────────────────────────────────────────────────────────────
# debug | info | warn | error | fatal. Defaults: debug in dev, info in prod.
LOG_LEVEL=debug

# ─── Database (Postgres) ───────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=metriqflow
DB_USER=postgres
DB_PASSWORD=
# Set to "true" when connecting to managed Postgres that requires SSL
# (Neon/Supabase/Timeweb/Yandex Cloud/RDS). Leave unset for local.
DB_SSL=false

# ─── Auth / JWT ────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_REFRESH_SECRET=

# ─── Cookies ───────────────────────────────────────────────────────────────
# lax (default) — safest for same-site deploys.
# none — required if frontend and backend live on different domains.
#        MUST be combined with HTTPS so the Secure flag kicks in.
# strict — most aggressive, breaks top-level navigation flows.
COOKIE_SAMESITE=lax

# ─── CORS ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Single source of truth — DO NOT
# hardcode additional ports in src/app.ts.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Legacy fallback (used only if CORS_ORIGINS is unset).
FRONTEND_URL=http://localhost:3000

# ─── VK ────────────────────────────────────────────────────────────────────
# Service token from VK app settings. Required for VK community analytics.
# OAuth/user tokens are disabled by VK since 2024-06-25, this is the only
# key that still works.
VK_SERVICE_TOKEN=

# ─── Telegram Bot ──────────────────────────────────────────────────────────
# BotFather token. Used to deliver scheduled reports to linked accounts.
BOT_TOKEN=

# ─── Email (SMTP) ──────────────────────────────────────────────────────────
# If SMTP_USER is empty the backend prints the email to logs at debug level
# instead of sending — useful for local dev.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false

# ─── PDF generation ────────────────────────────────────────────────────────
# Path to a TTF font with Cyrillic support. Defaults to a bundled font.
PDF_FONT_PATH=

# ─── AI (Anthropic) ────────────────────────────────────────────────────────
# API key from console.anthropic.com — required for AI Insights feature.
# Leave empty to disable (endpoints return 503).
ANTHROPIC_API_KEY=

# ─── Admin ─────────────────────────────────────────────────────────────────
# Comma-separated emails granted is_admin on boot (seedAdmins).
ADMIN_EMAILS=

# ─── Sentry ────────────────────────────────────────────────────────────────
# Error monitoring DSN from sentry.io project settings.
# Leave empty to disable Sentry (default in dev).
SENTRY_DSN=
# Release identifier (git sha) for grouping events by version. Set by CI.
SENTRY_RELEASE=
