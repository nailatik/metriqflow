# ─── Backend API ──────────────────────────────────────────────────────────
# Browser-side base URL for backend requests. Also used in CSP connect-src.
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Public site URL ──────────────────────────────────────────────────────
# Used as metadataBase for og:image absolute URLs. Set this to the real
# production origin (https://metriqflow.com) so OG previews work on social.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Telegram bot ─────────────────────────────────────────────────────────
# Public username (without @) — embedded in the "Open Telegram" deep link
# shown after the user generates a linking token.
NEXT_PUBLIC_BOT_USERNAME=

# ─── VK ────────────────────────────────────────────────────────────────────
# NOTE: no frontend VK env var is needed. VK OAuth was disabled by VK on
# 2024-06-25; VK analytics run server-side via the backend VK_SERVICE_TOKEN.
# (NEXT_PUBLIC_VK_APP_ID is not referenced anywhere in the frontend.)

# ─── Sentry ────────────────────────────────────────────────────────────────
# Error monitoring DSN from sentry.io project settings (browser-accessible).
# Leave empty to disable Sentry (default in dev).
NEXT_PUBLIC_SENTRY_DSN=
