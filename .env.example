# ─── Root compose env (host: ./.env, gitignored) ────────────────────────────
# Infra-level vars compose interpolates into docker-compose.yml. Backend app
# secrets (JWT, tokens, SMTP, ANTHROPIC, SENTRY) go in ./backend/.env instead.

# Postgres credentials — used by the postgres service AND injected into backend.
DB_USER=metriqflow
DB_PASSWORD=change-me-strong
DB_NAME=metriqflow

# Public domains (DNS A records → this VPS). Caddy issues TLS for both.
SITE_DOMAIN=metriqflow.com
API_DOMAIN=api.metriqflow.com
ACME_EMAIL=you@example.com

# Frontend build args (baked into the Next bundle at build time).
# API URL must be the public backend origin so the browser can reach it.
NEXT_PUBLIC_API_URL=https://api.metriqflow.com
NEXT_PUBLIC_SITE_URL=https://metriqflow.com
NEXT_PUBLIC_BOT_USERNAME=
NEXT_PUBLIC_SENTRY_DSN=
